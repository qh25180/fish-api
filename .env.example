# ═══ 基础配置 ═══

# 文本文件存放目录
TEXT_FILES_DIR=./novels

# 允许的文件扩展名（逗号分隔）
TEXT_FILE_EXTENSIONS=.txt,.md

# 默认编码（auto 表示自动检测）
DEFAULT_ENCODING=auto

# 通用 API 访问口令（不配置或留空则不验证）
API_TOKEN=qhapi-token


# ═══ 远程拉取下载接口（从 URL 拉取文件到服务器）═══

# 是否启用远程拉取下载
REMOTE_DOWNLOAD_ENABLED=false

# 是否允许下载内网地址的文件
REMOTE_DOWNLOAD_ALLOW_INTRANET=false


# ═══ 文件上传接口（从本地上传到服务器）═══

# 是否启用文件上传
UPLOAD_ENABLED=false

# 上传超时时间（秒，大文件可适当增加）
UPLOAD_TIMEOUT_SECONDS=300

# 分片上传每片大小（KB）
UPLOAD_CHUNK_SIZE_KB=512


# ═══ 文件下载接口（从服务器下载到本地）═══

# 是否启用文件下载
FILE_DOWNLOAD_ENABLED=false


# ═══ 站点源配置 ═══

# aHR0cHM6Ly96eGNzLnppcA==
SOURCE_A_ENABLED=false
SOURCE_A_URL=https://example.com
SOURCE_A_NAME=示例源A

# aHR0cHM6Ly96eGNzLmRtbGIuY2Y=
SOURCE_B_ENABLED=false
SOURCE_B_URL=https://example.com
SOURCE_B_PATH=/
SOURCE_B_NAME=示例源B


# ═══ 文件重命名 ═══

# 下载/上传后自动将文件名转为拼音（PascalCase，如 YanYuJiangNan.txt）
FILE_RENAME_PINYIN=false


# ═══ 传输限制 ═══

# 单个文件大小上限（MB）
MAX_FILE_SIZE_MB=50

# 远程拉取下载超时（秒）
DOWNLOAD_TIMEOUT_SECONDS=30

# 文本文件存放目录
TEXT_FILES_DIR=./novels

# 允许的文件扩展名（逗号分隔）
TEXT_FILE_EXTENSIONS=.txt,.md

# 默认编码（auto 表示自动检测）
DEFAULT_ENCODING=auto

# 是否启用远程下载接口（true/false，默认关闭）
DOWNLOAD_ENABLED=false

# 远程下载访问口令（不配置或留空则不验证）
DOWNLOAD_TOKEN=qhapi-token

# 允许内网地址下载（true/false，默认关闭，需 DOWNLOAD_ENABLED=true）
DOWNLOAD_ALLOW_INTRANET=false

# 下载文件大小上限（MB）
MAX_FILE_SIZE_MB=50

# 下载超时时间（秒）
DOWNLOAD_TIMEOUT_SECONDS=30

# ═══ 基础配置 ═══

# 文本文件存放目录
TEXT_FILES_DIR=./novels

# 允许的文件扩展名（逗号分隔）
TEXT_FILE_EXTENSIONS=.txt,.md

# 默认编码（auto 表示自动检测）
DEFAULT_ENCODING=auto

# 通用 API 访问口令（不配置或留空则不验证）
API_TOKEN=qhapi-token


# ═══ 远程拉取下载接口（从 URL 拉取文件到服务器）═══

# 是否启用远程拉取下载
REMOTE_DOWNLOAD_ENABLED=false

# 是否允许下载内网地址的文件
REMOTE_DOWNLOAD_ALLOW_INTRANET=false


# ═══ 文件上传接口（从本地上传到服务器）═══

# 是否启用文件上传
UPLOAD_ENABLED=false


# ═══ 文件下载接口（从服务器下载到本地）═══

# 是否启用文件下载
FILE_DOWNLOAD_ENABLED=false


# ═══ 传输限制 ═══

# 单个文件大小上限（MB）
MAX_FILE_SIZE_MB=50

# 远程拉取下载超时（秒）
DOWNLOAD_TIMEOUT_SECONDS=30
